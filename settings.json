{
  "text_rendering_mode": "subpixel",
  "buffer_font_weight": 450.0,
  "show_whitespaces": "boundary",
  "project_panel": {
    "dock": "right",
  },
  "debugger": {
    "dock": "right",
  },
  "ui_font_weight": 450.0,
  "use_system_window_tabs": false,
  "tab_bar": {
    "show": true,
  },
  "title_bar": {
    "show_onboarding_banner": false,
  },
  "icon_theme": {
    "mode": "system",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "agent_buffer_font_size": 14.0,
  "vim_mode": true,
  "relative_line_numbers": "enabled",
  "edit_predictions": {
    "provider": "zed",
    "mode": "subtle",
    "copilot": {
      "proxy_no_verify": null,
    },
    "enabled_in_text_threads": false,
  },
  "autosave": "on_focus_change",
  "terminal": {
    "dock": "right",
  },
  "agent": {
    "default_model": {
      "provider": "google",
      "model": "gemini-2.5-pro",
    },
    "model_parameters": [],
  },
  "base_keymap": "VSCode",
  "telemetry": {
    "metrics": false,
    "diagnostics": false,
  },
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "ui_font_size": 16.0,
  "ui_font_family": "JetBrainsMono Nerd Font",
  "agent_ui_font_size": 15.0,
  "buffer_font_size": 14.5,
  "buffer_line_height": { "custom": 2.0999999046325684 },
  "theme": {
    "mode": "dark",
    "light": "One Dark",
    "dark": "Polish Winters",
  },
  "vim": {
    "default_mode": "normal",
    "use_system_clipboard": "always",
    "use_smartcase_find": true,
    "toggle_relative_line_numbers": true,
    "highlight_on_yank_duration": 800,
    "custom_digraphs": {
      "fz": "🧟‍♀️",
    },
  },
  "diagnostics": {
    "button": true,
    "include_warnings": true,
    "inline": {
      "enabled": true,
      "update_debounce_ms": 150,
      "padding": 4,
      "min_column": 0,
      "max_severity": null,
    },
  },

  "inlay_hints": {
    "enabled": true,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true,
    "show_background": false,
    "edit_debounce_ms": 700,
    "scroll_debounce_ms": 50,
    "toggle_on_modifiers_press": null,
  },
}
